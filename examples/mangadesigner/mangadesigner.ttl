<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting>
      a       dsp:DescriptionTemplate , rdfs:Resource , rdfs:Class , owl:Class ;
      rdfs:label "Setting" ;
      rdfs:subClassOf <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-title> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-PlotSetting> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-description> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-CharacterSetting> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-relation> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-image> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting-StageSetting> ;
