<http://mdlab.slis.tsukuba.ac.jp/schema/dmm>
      a       owl:Ontology ;
      reg:comment " マンガの設計メタデータDSP" ;
      reg:created "2013-12-02" ;
      reg:creator <http://purl.org/metainfo/indvs/organization/G0000021> ;
      reg:owner <http://purl.org/metainfo/indvs/organization/G0000021> ;
      reg:primaryDescription
              <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN> ;
      reg:registered "2013-12-02" ;
      reg:registrant "tsuna" ;
      reg:title " DSP for Manga Design Metadata" .

<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN>
      a       dsp:DescriptionTemplate , rdfs:Resource , rdfs:Class , owl:Class ;
      rdfs:label "MAIN" ;
      rdfs:subClassOf <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN> , <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN-Setting> ;
      dsp:resourceClass dmm:Manga ;
      dsp:valueURIOccurrence
              "mandatory" ;
      reg:idField "MangaID" ;
      reg:statementOrder "Setting" .

<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN-Setting>
      a       rdfs:Resource , rdfs:Class , owl:Restriction , dsp:StatementTemplate ;
      rdfs:comment "マンガの設定" ;
      rdfs:label "Setting" ;
      rdfs:subClassOf <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#MAIN-Setting> ;
      owl:maxQualifiedCardinality
              "-" ;
      owl:minQualifiedCardinality
              "0" ;
      owl:onClass <http://mdlab.slis.tsukuba.ac.jp/schema/dmm#Setting> ;
      owl:onProperty dmm:hasSetting .

<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#PlotSetting>
      a       dsp:DescriptionTemplate , rdfs:Resource , rdfs:Class , owl:Class ;
