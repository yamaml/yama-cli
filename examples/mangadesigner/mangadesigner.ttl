      dsp:resourceClass dmm:StorySetting ;
      dsp:valueURIOccurrence
              "mandatory" ;
      reg:idField "PlotSettingID" ;
      reg:statementOrder "cast,stage" .

<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#StageSetting>
