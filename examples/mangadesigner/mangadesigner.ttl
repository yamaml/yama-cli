      dsp:valueURIOccurrence
              "mandatory" ;
      reg:idField "SettingID" ;
      reg:statementOrder "title,image,description,relation,CharacterSetting,StageSetting,PlotSetting" .

<http://mdlab.slis.tsukuba.ac.jp/schema/dmm#CharacterSetting>
      a       dsp:DescriptionTemplate , rdfs:Resource , rdfs:Class , owl:Class ;
