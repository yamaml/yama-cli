digraph YAMA {
  bgcolor="#ffffff";
  rankdir=TB;
  pad="0.6";
  nodesep=0.5;
  ranksep=0.8;
  splines=curved;
  fontname="Helvetica";
  node [shape=plaintext fontname="Helvetica"];
  edge [fontname="Helvetica" fontsize=9];

  "character" [label=<
    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" COLOR="#666666" BGCOLOR="#ffffff" STYLE="ROUNDED">
      <TR><TD COLSPAN="4" BGCOLOR="#FFCE9F" CELLPADDING="8" ALIGN="CENTER" PORT="_header"><FONT POINT-SIZE="14"><B>Character</B></FONT><BR/><FONT POINT-SIZE="10" COLOR="#666666"><I>foaf:Person</I></FONT></TD></TR>
      <HR/>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>foaf:name</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">xsd:string</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">1</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="name"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>foaf:familyName</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">xsd:string</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">1</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="familyName"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>foaf:firstName</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">xsd:string</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">1</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="firstName"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:additionalName</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">xsd:string</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..1</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="additionalName"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:jobTitle</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">xsd:string</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..1</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="jobTitle"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:parent</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="parents"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:children</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="children"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>foaf:knows</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="knows"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>rdfs:seeAlso</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="wikidata"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:byArtist</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="byArtist"></TD></TR>
    </TABLE>
  >];

  "address" [label=<
    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" COLOR="#666666" BGCOLOR="#ffffff" STYLE="ROUNDED">
      <TR><TD COLSPAN="4" BGCOLOR="#B8D4E3" CELLPADDING="8" ALIGN="CENTER" PORT="_header"><FONT POINT-SIZE="14"><B>address</B></FONT></TD></TR>
      <HR/>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:streetAddress</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="street"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:addressLocality</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="locality"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:addressRegion</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="region"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:addressRegion</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="country"></TD></TR>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:postalCode</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="postalCode"></TD></TR>
    </TABLE>
  >];

  "artist" [label=<
    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="0" COLOR="#666666" BGCOLOR="#ffffff" STYLE="ROUNDED">
      <TR><TD COLSPAN="4" BGCOLOR="#C8E6C9" CELLPADDING="8" ALIGN="CENTER" PORT="_header"><FONT POINT-SIZE="14"><B>Character</B></FONT><BR/><FONT POINT-SIZE="10" COLOR="#666666"><I>foaf:Person</I></FONT></TD></TR>
      <HR/>
      <TR><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>schema:name</B></FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9"> </FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#ffffff" CELLPADDING="2" WIDTH="2" PORT="name"></TD></TR>
      <TR><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="10"><B>rdfs:isDefinedBy</B></FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="9">URI</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="5" ALIGN="RIGHT"><FONT COLOR="#888888" POINT-SIZE="9">0..*</FONT></TD><TD BGCOLOR="#f5f5f5" CELLPADDING="2" WIDTH="2" PORT="wikidata"></TD></TR>
    </TABLE>
  >];

}